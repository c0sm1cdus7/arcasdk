{
    "extends": "./tsconfig.build.json",
    "compilerOptions": {
        "rootDir": ".",
        "noEmit": true,
        "paths": {
            "@arcasdk/core/*": ["./*"],
            "@domain/*": ["src/domain/*"],
            "@application/*": ["src/application/*"],
            "@infrastructure/*": ["src/infrastructure/*"]
        }
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules"]
}
